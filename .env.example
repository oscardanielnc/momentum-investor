# investor — plantilla de configuración. Copia este archivo a `.env` y rellena tus claves.
#   cp .env.example .env   (Linux/VM)   ·   copy .env.example .env   (Windows)
# El `.env` real está en .gitignore y NUNCA se sube al repo.

# --- Alpaca (broker + datos de mercado) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Datos históricos para research/backtests (opcional; solo si corres research/) ---
DATABENTO_API_KEY=

# --- IA para la justificación en prosa (opcional; sin clave usa texto determinista) ---
AI_ENGINE=deepseek            # deepseek | glm | claude
DEEPSEEK_API_KEY=

# --- Modo de ejecución del robot ---
# DRY_RUN=true               → solo loguea, no envía órdenes (seguro)
# DRY_RUN=false + LIVE=false → PAPER (cuenta de práctica)
# DRY_RUN=false + LIVE=true  → REAL (solo tras validar en demo)
INVESTOR_DRY_RUN=true
INVESTOR_ALPACA_LIVE=false
INVESTOR_HEARTBEAT_S=900
